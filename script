    local function teleportBehindCharacter(targetCharacter)
        local myHRP = getHumanoidRootPart()
        local targetHRP = targetCharacter and targetCharacter:FindFirstChild("HumanoidRootPart")
        if not (myHRP and targetHRP) then return false end

        local behindOffset = targetHRP.CFrame.LookVector * -autoFarmBehindDistance
        local targetPos = targetHRP.Position + behindOffset
        myHRP.CFrame = CFrame.new(targetPos, targetHRP.Position)
        return true
    end

    local function teleportBehindNPC(targetNPC)
        return teleportBehindCharacter(targetNPC)
    end

    local function gripAutoFarmNPC(targetNPC)
        local gripStartedAt = tick()

        while autoFarmEnabled and targetNPC and targetNPC.Parent and isNPCDowned(targetNPC) and (tick() - gripStartedAt) < 6 do
            local hrp = getHumanoidRootPart()
            if hrp then
                fireGripOnNPC(targetNPC, hrp)
            end
            task.wait(npcGripInterval)
        end
    end


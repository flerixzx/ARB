    local autoGripNPCsEnabled = false
    local npcGripInterval = 0.005
    local npcGripBurstCount = 8
    local npcGripMaxDistance = 45

    local function isTargetNPC(npc)
        return npc and (npc.Name == "RegularNationNpc" or npc.Name == "RegulationNationNpc")
    end

    local function getNPCHumanoid(npc)
        return npc and npc:FindFirstChildOfClass("Humanoid")
    end

    local function isNPCAlive(npc)
        local npcHumanoid = getNPCHumanoid(npc)
        return npcHumanoid and npcHumanoid.Health > 10
    end

    local function isNPCDowned(npc)
        local npcHumanoid = getNPCHumanoid(npc)
        return npcHumanoid and npcHumanoid.Health <= 10
    end

    local function getClosestNPC(maxDistance, healthCheck)
        local hrp = getHumanoidRootPart()
        local livesFolder = workspace:FindFirstChild("Lives") or workspace:FindFirstChild("lives")
        if not (hrp and livesFolder) then return nil, nil end

        local closestNPC
        local shortestDistance = maxDistance or math.huge

        for _, npc in ipairs(livesFolder:GetChildren()) do
            if isTargetNPC(npc) then
                local npcHRP = npc:FindFirstChild("HumanoidRootPart")
                if npcHRP and (not healthCheck or healthCheck(npc)) then
                    local dist = (npcHRP.Position - hrp.Position).Magnitude
                    if dist <= shortestDistance then
                        shortestDistance = dist
                        closestNPC = npc
                    end
                end
            end
        end

        return closestNPC, hrp
    end

    local function getClosestFarmNPC(maxDistance)
        return getClosestNPC(maxDistance, isNPCAlive)
    end

    local function getClosestGripNPC(maxDistance)
        return getClosestNPC(maxDistance, isNPCDowned)
    end

    local function getGripEvent()
        return player.Character and player.Character:FindFirstChild("Scripts")

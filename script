    local function fireGripOnNPC(targetNPC, hrp)
        local gripEvent = getGripEvent()
        if not (targetNPC and targetNPC.Parent and hrp and gripEvent) then return false end

        local args = {"Kill", targetNPC, hrp.Position + Vector3.new(1, 2, 0)}
        for _ = 1, npcGripBurstCount do
            gripEvent:FireServer(unpack(args))
        end
        return true
    end


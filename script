    local function getScreenCenter()
        local camera = workspace.CurrentCamera
        local viewportSize = camera and camera.ViewportSize
        if not viewportSize then return Vector2.new(0, 0) end
        return Vector2.new(viewportSize.X / 2, viewportSize.Y / 2)
    end

    local function getProjectileAimbotTarget()
        local camera = workspace.CurrentCamera
        if not camera then return nil end

        local screenCenter = getScreenCenter()
        local closestPart
        local closestDistance = projectileAimbotFOV

        for _, targetPlayer in ipairs(Players:GetPlayers()) do
            if targetPlayer ~= LocalPlayer and not isAuraWhitelisted(targetPlayer) then
                local character = targetPlayer.Character
                local humanoid = character and character:FindFirstChildOfClass("Humanoid")
                local targetPart = character and (character:FindFirstChild("Head") or character:FindFirstChild("HumanoidRootPart"))
                if targetPart and humanoid and humanoid.Health > 0 then
                    local screenPosition, onScreen = camera:WorldToViewportPoint(targetPart.Position)
                    if onScreen and screenPosition.Z > 0 then
                        local distance = (Vector2.new(screenPosition.X, screenPosition.Y) - screenCenter).Magnitude
                        if distance <= closestDistance then
                            closestDistance = distance
                            closestPart = targetPart
                        end
                    end
                end
            end
        end

        return closestPart
    end

    local function remoteLooksCurvable(remote)
        local name = tostring(remote and remote.Name or ""):lower()
        local parentName = tostring(remote and remote.Parent and remote.Parent.Name or ""):lower()
        local fullName = ""
        pcall(function()
            fullName = tostring(remote:GetFullName()):lower()
        end)

        return name:find("projectile")
            or name:find("curve")
            or name:find("shoot")
            or name:find("cast")
            or parentName:find("projectile")
            or parentName:find("curve")
            or fullName:find("projectile")
            or fullName:find("curv")
    end

    local function aimProjectileArgs(args, targetPosition)
        local changed = false
        for index, value in ipairs(args) do
            if typeof(value) == "Vector3" then
                args[index] = targetPosition
                changed = true
            elseif typeof(value) == "CFrame" then
                args[index] = CFrame.new(value.Position, targetPosition)
                changed = true
            elseif typeof(value) == "table" then
                for key, nestedValue in pairs(value) do
                    if typeof(nestedValue) == "Vector3" and tostring(key):lower():find("pos") then
                        value[key] = targetPosition
                        changed = true
                    elseif typeof(nestedValue) == "CFrame" then
                        value[key] = CFrame.new(nestedValue.Position, targetPosition)
                        changed = true
                    end
                end
            end
        end

        return changed
    end

    local function setProjectileAimbotState(enabled)
        projectileAimbotEnabled = enabled
        if projectileAimbotHooked or type(hookmetamethod) ~= "function" or type(newcclosure) ~= "function" then
            return projectileAimbotHooked
        end

        originalNamecall = hookmetamethod(game, "__namecall", newcclosure(function(self, ...)
            local method = getnamecallmethod()
            local args = {...}

            if projectileAimbotEnabled and method == "FireServer" and remoteLooksCurvable(self) then
                local targetPart = getProjectileAimbotTarget()
                if targetPart then
                    aimProjectileArgs(args, targetPart.Position)
                    return originalNamecall(self, unpack(args))
                end
            end

            return originalNamecall(self, ...)
        end))

        projectileAimbotHooked = true
        return true
    end


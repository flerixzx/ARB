                label.TextColor3 = hitboxColor
            end
        end
    end

    local function updateESPState()
        if espConnection then
            espConnection:Disconnect()
            espConnection = nil
        end

        if not playerESPEnabled and not npcESPEnabled then
            clearESPBillboards(playerESPBillboards)
            clearESPBillboards(npcESPBillboards)
            return
        end

        espConnection = RunService.Heartbeat:Connect(function()
            local localHRP = getHumanoidRootPart()

            if playerESPEnabled then
                for _, targetPlayer in ipairs(Players:GetPlayers()) do
                    if targetPlayer ~= LocalPlayer and targetPlayer.Character then
                        local targetHRP = targetPlayer.Character:FindFirstChild("HumanoidRootPart")
                        local targetHumanoid = targetPlayer.Character:FindFirstChildOfClass("Humanoid")
                        if targetHRP then
                            local billboard = playerESPBillboards[targetPlayer.Character]
                            local espText = formatHealthText(targetPlayer.Name, targetHumanoid)
                            if not (billboard and billboard.Parent == targetHRP) then
                                removeESPBillboard(playerESPBillboards, targetPlayer.Character)
                                billboard = createESPBillboard(targetHRP, espText)
                                billboard.Parent = targetHRP
                                playerESPBillboards[targetPlayer.Character] = billboard
                            else
                                setESPText(billboard, espText)
                            end
                        end
                    end
                end

                for character in pairs(playerESPBillboards) do
                    if not character.Parent then
                        removeESPBillboard(playerESPBillboards, character)
                    end
                end
            else
                clearESPBillboards(playerESPBillboards)
            end

            if npcESPEnabled then
                local livesFolder = workspace:FindFirstChild("Lives") or workspace:FindFirstChild("lives")
                if livesFolder and localHRP then
                    for _, npc in ipairs(livesFolder:GetChildren()) do
                        if isTargetNPC(npc) then
                            local npcHRP = npc:FindFirstChild("HumanoidRootPart")
                            local npcHumanoid = getNPCHumanoid(npc)
                            if npcHRP then
                                local withinRange = (npcHRP.Position - localHRP.Position).Magnitude <= npcESPMaxDistance
                                if withinRange then
                                    local billboard = npcESPBillboards[npc]
                                    local espText = formatHealthText("NPC", npcHumanoid)
                                    if not (billboard and billboard.Parent == npcHRP) then
                                        removeESPBillboard(npcESPBillboards, npc)
                                        billboard = createESPBillboard(npcHRP, espText)
                                        billboard.Parent = npcHRP
                                        npcESPBillboards[npc] = billboard
                                    else
                                        setESPText(billboard, espText)
                                    end
                                else
                                    removeESPBillboard(npcESPBillboards, npc)
                                end
                            end
                        end
                    end
                else
                    clearESPBillboards(npcESPBillboards)
                end

                for npc in pairs(npcESPBillboards) do
                    if not npc.Parent then
                        removeESPBillboard(npcESPBillboards, npc)
                    end
                end
            else
                clearESPBillboards(npcESPBillboards)
            end
        end)
    end



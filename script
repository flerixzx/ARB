    local function findSelectedMatch(currentValue, selectedValues)
        if currentValue == "" then return nil end

        for _, selectedValue in ipairs(selectedValues) do
            if currentValue == selectedValue or currentValue:find(selectedValue, 1, true) then
                return selectedValue
            end
        end

        return nil
    end

    local function stopSpinIfMatched(spinType, currentValue, selectedValues)
        local matchedValue = findSelectedMatch(currentValue, selectedValues)
        if not matchedValue then return false end

        if spinType == "Family" then
            autoSpinFamilyEnabled = false
        else
            autoSpinTraitEnabled = false
        end

        Fluent:Notify({Title = spinType .. " Match", Content = "You rolled " .. spinType:lower() .. ": " .. matchedValue, Duration = 5})
        return true
    end

    local function spinForFamily()

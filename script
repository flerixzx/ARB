    -- Hitbox Expander
    local hitboxExpanderEnabled = false
    local hitboxSizeStuds = 8
    local hitboxTransparency = 0.5
    local hitboxConnection
    local expandedHitboxes = {}
    local originalHitboxProperties = {}

    local function removeHitbox(character)
        local targetHRP = expandedHitboxes[character]
        local originalProperties = originalHitboxProperties[character]

        if targetHRP and targetHRP.Parent and originalProperties then
            targetHRP.Size = originalProperties.Size
            targetHRP.Transparency = originalProperties.Transparency
            targetHRP.Color = originalProperties.Color
            targetHRP.Material = originalProperties.Material
            targetHRP.CanCollide = originalProperties.CanCollide
            targetHRP.CanTouch = originalProperties.CanTouch
            targetHRP.CanQuery = originalProperties.CanQuery
        end

        expandedHitboxes[character] = nil
        originalHitboxProperties[character] = nil
    end

    local function clearAllHitboxes()
        for character in pairs(expandedHitboxes) do
            removeHitbox(character)
        end
    end

    local function updateHitboxProperties(targetHRP)
        targetHRP.Size = Vector3.new(hitboxSizeStuds, hitboxSizeStuds, hitboxSizeStuds)
        targetHRP.Color = hitboxColor
        targetHRP.Material = Enum.Material.ForceField
        targetHRP.Transparency = hitboxTransparency
        targetHRP.CanCollide = false
        targetHRP.CanTouch = true
        targetHRP.CanQuery = true
    end

    local function refreshAllExpandedHitboxes()
        for _, targetHRP in pairs(expandedHitboxes) do
            if targetHRP and targetHRP.Parent then
                updateHitboxProperties(targetHRP)
            end
        end
    end

    local function getOrCreateHitboxForCharacter(targetCharacter)
        local targetHRP = targetCharacter and targetCharacter:FindFirstChild("HumanoidRootPart")
        if not targetHRP then return end

        local trackedHRP = expandedHitboxes[targetCharacter]
        if trackedHRP ~= targetHRP then
            removeHitbox(targetCharacter)

            originalHitboxProperties[targetCharacter] = {
                Size = targetHRP.Size,
                Transparency = targetHRP.Transparency,
                Color = targetHRP.Color,
                Material = targetHRP.Material,
                CanCollide = targetHRP.CanCollide,
                CanTouch = targetHRP.CanTouch,
                CanQuery = targetHRP.CanQuery
            }
            expandedHitboxes[targetCharacter] = targetHRP
        end

        updateHitboxProperties(targetHRP)
    end

    local function setHitboxExpanderState(enabled)
        hitboxExpanderEnabled = enabled

        if hitboxConnection then
            hitboxConnection:Disconnect()
            hitboxConnection = nil
        end

        if not enabled then
            clearAllHitboxes()
            return
        end

        hitboxConnection = RunService.Heartbeat:Connect(function()
            for _, targetPlayer in ipairs(Players:GetPlayers()) do
                if targetPlayer ~= LocalPlayer and targetPlayer.Character then
                    getOrCreateHitboxForCharacter(targetPlayer.Character)
                end
            end

            for character, targetHRP in pairs(expandedHitboxes) do
                if not character.Parent or not targetHRP.Parent then
                    removeHitbox(character)
                end
            end
        end)
    end


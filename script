    local function getClosestGripPlayerCharacter(maxDistance)
        local hrp = getHumanoidRootPart()
        if not hrp then return nil, nil end

        local closestCharacter
        local closestDistance = maxDistance or math.huge

        for _, targetPlayer in ipairs(Players:GetPlayers()) do
            local character = targetPlayer.Character
            local targetHRP = character and character:FindFirstChild("HumanoidRootPart")
            if targetPlayer ~= LocalPlayer and not whitelist[targetPlayer.Name] and targetHRP and isCharacterDowned(character) then
                local distance = (targetHRP.Position - hrp.Position).Magnitude
                if distance <= closestDistance then
                    closestCharacter = character
                    closestDistance = distance
                end
            end
        end

        return closestCharacter, hrp
    end

    local function fireGripOnPlayerCharacter(targetCharacter, hrp)
        local gripEvent = getGripEvent()
        if not (targetCharacter and targetCharacter.Parent and hrp and gripEvent) then return false end

        local args = {"Kill", targetCharacter, hrp.Position + Vector3.new(1, 2, 0)}
        for _ = 1, playerGripBurstCount do
            gripEvent:FireServer(unpack(args))
        end
        return true
    end


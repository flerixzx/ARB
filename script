    local function isAntiCheatScript(instance)
        if not (instance and (instance:IsA("LocalScript") or instance:IsA("Script"))) then
            return false
        end

        for _, scriptName in ipairs(AntiCheatScriptNames) do
            if instance.Name == scriptName then
                return true
            end
        end

        return false
    end

    local function quarantineAntiCheatScript(AntiCheatScript)
        if not isAntiCheatScript(AntiCheatScript) or quarantinedAntiCheatScripts[AntiCheatScript] then
            return false
        end

        quarantinedAntiCheatScripts[AntiCheatScript] = AntiCheatScript.Parent
        AntiCheatScript:SetAttribute("ARBOriginalParentPath", AntiCheatScript:GetFullName())
        AntiCheatScript.Parent = nil
        return true
    end

    local function quarantineAntiCheatScriptsFromRog(rogFolder)
        local removed = 0
        if not rogFolder then return removed end

        for _, child in ipairs(rogFolder:GetChildren()) do
            if quarantineAntiCheatScript(child) then
                removed += 1
            end
        end

        return removed
    end


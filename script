    local function formatHealthText(name, humanoid)
        if not humanoid then
            return name .. " | HP: ?"
        end

        local health = math.max(0, math.floor(humanoid.Health + 0.5))
        local maxHealth = math.max(0, math.floor(humanoid.MaxHealth + 0.5))
        return string.format("%s | HP: %d/%d", name, health, maxHealth)
    end

    local function setESPText(billboard, text)

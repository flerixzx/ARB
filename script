    local function getAuraEvent()
        local character = LocalPlayer.Character
        local backpack = LocalPlayer:FindFirstChildOfClass("Backpack")
        local weapon = nil

        -- 1. Check if the weapon is currently equipped in the Character
        if character then
            for _, name in ipairs(validWeapons) do
                local found = character:FindFirstChild(name)
                if found then
                    weapon = found
                    break
                end
            end
        end

        -- 2. If not equipped, check the Backpack/Inventory
        if not weapon and backpack then
            for _, name in ipairs(validWeapons) do
                local found = backpack:FindFirstChild(name)
                if found then
                    weapon = found
                    break
                end
            end
        end

        -- 3. If a weapon was found, safely navigate to the RemoteEvent
        return weapon and weapon:FindFirstChild("Scripts")
            and weapon.Scripts:FindFirstChild("Main")
            and weapon.Scripts.Main:FindFirstChild("Event")
    end

